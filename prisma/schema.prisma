  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade, map: "fk_invitations_organization")
  projects        projects?     @relation(fields: [project_id], references: [id], onDelete: Cascade, map: "fk_invitations_project")
  roles           roles         @relation(fields: [role_id], references: [id], map: "fk_invitations_role")
}

model labels {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id  String        @db.Uuid
  name        String        @db.VarChar(100)
  description String?
  color_code  String        @db.VarChar(20)
  is_active   Boolean       @default(true)
  created_by  String        @db.Uuid
  created_at  DateTime      @default(now()) @db.Timestamp(6)
  updated_at  DateTime      @default(now()) @db.Timestamp(6)
  users       users         @relation(fields: [created_by], references: [id], map: "fk_labels_created_by")
  projects    projects      @relation(fields: [project_id], references: [id], onDelete: Cascade, map: "fk_labels_project")
